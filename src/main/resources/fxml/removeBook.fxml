<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="removeAnchorPane" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.ua._klaidi4_.lmv_lab3.controllers.RemoveBookController">
    <children>
        <TextField fx:id="removeBookText" layoutX="300.0" layoutY="29.0" prefHeight="42.0" prefWidth="400.0" promptText="Введіть ID книги яку хочете списати" />
        <Button fx:id="removeBookButton" layoutX="731.0" layoutY="29.0" mnemonicParsing="false" prefHeight="42.0" prefWidth="100.0" text="Списати" />
        <TableView fx:id="removeBookTable" layoutX="20.0" layoutY="98.0" prefHeight="402.0" prefWidth="960.0">
            <columns>
                <TableColumn fx:id="removeBookTableColumID" prefWidth="30.0" text="ID" />
                <TableColumn fx:id="removeBookTableColumTitle" prefWidth="470.0" text="Назва книг" />
                <TableColumn fx:id="removeBookTableColumAuthor" prefWidth="300.0" text="Автори книг" />
                <TableColumn fx:id="removeBookTableColumYear" prefWidth="160.0" text="Рік видання" />
            </columns>
        </TableView>
        <Button fx:id="removeBookButtonBack" layoutX="240.0" layoutY="513.0" mnemonicParsing="false" prefHeight="67.0" prefWidth="602.0" text="Повернутись в меню">
            <font>
                <Font size="31.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
